# Gemini / Google Generative API (recommended: service account JSON)
# Option A: Use a Google service account JSON file (recommended for servers)
# Download the JSON key and set the path below.
GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account-key.json

# Option B: Use an API key or OAuth access token (less recommended)
# If using an API key, set GEMINI_API_KEY and optionally GEMINI_API_URL
GEMINI_PROVIDER=google
GEMINI_API_KEY=
GEMINI_API_URL=
GEMINI_MODEL=chat-bison

# Other fallbacks
# OPENAI_API_KEY=   # if you want to use OpenAI-compatible provider as a fallback
